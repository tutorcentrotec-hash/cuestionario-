<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Evaluación Parcial - Seguimiento y Mejora Continua</title>
<style>
body{font-family:'Segoe UI',Arial;background:linear-gradient(135deg,#0f172a,#1e3a8a,#2563eb);margin:0;padding:20px;color:#1f2937}
.container{max-width:900px;margin:auto;background:#ffffff;padding:30px;border-radius:16px;box-shadow:0 20px 40px rgba(0,0,0,0.25)}
h1{text-align:center;color:#111827}
.subtitle{text-align:center;color:#6b7280;margin-bottom:20px}
.progress{height:8px;background:#e5e7eb;border-radius:10px;margin:20px 0}
.bar{height:100%;background:#2563eb;border-radius:10px;transition:.4s}
.card{padding:20px;border-radius:12px;background:#f8fafc;margin-bottom:15px;border-left:5px solid #2563eb}
.case{font-size:14px;color:#374151;margin-bottom:10px}
.q{font-size:18px;font-weight:600;margin-bottom:15px}
.opt{display:block;background:#fff;padding:12px;margin:8px 0;border-radius:8px;border:1px solid #d1d5db;cursor:pointer}
.opt:hover{background:#eff6ff;border-color:#2563eb}
.correct{background:#dcfce7;border-color:#16a34a}
.wrong{background:#fee2e2;border-color:#dc2626}
#next{display:none;background:#2563eb;color:#fff;border:none;padding:12px 20px;border-radius:8px;cursor:pointer}
.result{text-align:center;padding:30px}
.badge{padding:10px 20px;border-radius:50px;margin-top:10px;font-weight:bold}
.pass{background:#dcfce7;color:#16a34a}
.fail{background:#fee2e2;color:#dc2626}
.explain{margin-top:10px;font-size:14px;color:#4b5563}
</style>
</head>
<body>
<div class="container">
<h1>Evaluación Parcial</h1>
<div class="subtitle">Seguimiento y Mejora Continua en Auditoría Interna</div>
<div class="progress"><div id="bar" class="bar"></div></div>
<div id="quiz"></div>
<button id="next" onclick="nextQ()">Siguiente →</button>
</div>
<script>
const q=[
{case:"CASO: Después de la auditoría, no se realiza seguimiento a las recomendaciones.",q:"¿Cuál es el problema principal?",o:["Falta de evidencia","Falta de seguimiento","Falta de planificación","Falta de ética"],a:1,exp:"El seguimiento es clave para asegurar que las acciones se implementen."},

{case:"CASO: Se implementan acciones correctivas pero no se evalúa su efectividad.",q:"¿Qué debe hacer el auditor?",o:["Cerrar el caso","Emitir informe nuevo","Evaluar la eficacia","Ignorar resultados"],a:2,exp:"No basta implementar acciones, hay que verificar su efectividad."},

{case:"CASO: Los mismos errores aparecen en auditorías posteriores.",q:"¿Qué está fallando?",o:["Redacción","Mejora continua","Evidencia","Alcance"],a:1,exp:"La mejora continua busca evitar la repetición de hallazgos."},

{case:"CASO: El auditor realiza un solo seguimiento y cierra el hallazgo.",q:"¿Qué principio se incumple?",o:["Continuidad","Objetividad","Claridad","Confidencialidad"],a:0,exp:"El seguimiento debe mantenerse hasta asegurar cumplimiento."},

{case:"CASO: No se asignan responsables ni plazos a las acciones correctivas.",q:"¿Qué problema genera?",o:["Falta de evidencia","Falta de control","Falta de trazabilidad","Falta de ética"],a:2,exp:"Sin responsables ni plazos no hay control ni seguimiento efectivo."},

{case:"CASO: Las acciones correctivas no eliminan el riesgo identificado.",q:"¿Qué debe hacer el auditor?",o:["Cerrar hallazgo","Ignorar riesgo","Proponer nuevas acciones","Cambiar informe"],a:2,exp:"La mejora continua implica ajustar acciones hasta mitigar el riesgo."}
];

let i=0,s=0;

function load(){
let p=(i/q.length)*100;document.getElementById('bar').style.width=p+'%';
let html=`<div class='card'><div class='case'>${q[i].case}</div><div class='q'>${i+1}. ${q[i].q}</div>`;
q[i].o.forEach((op,idx)=>{html+=`<div class='opt' onclick='ans(${idx})'>${op}</div>`});
html+="</div>";
document.getElementById('quiz').innerHTML=html;
document.getElementById('next').style.display='none';
}

function ans(x){
let opts=document.querySelectorAll('.opt');
if(x===q[i].a){opts[x].classList.add('correct');s++;}
else{opts[x].classList.add('wrong');opts[q[i].a].classList.add('correct');}
document.getElementById('quiz').innerHTML+=`<div class='explain'>💡 ${q[i].exp}</div>`;
document.getElementById('next').style.display='block';
}

function nextQ(){
i++;
if(i<q.length)load(); else end();
}

function end(){
let pct=Math.round((s/q.length)*100);
let status=pct>=60?"APROBADO":"REPROBADO";
let cls=pct>=60?"pass":"fail";
document.getElementById('quiz').innerHTML=`<div class='result'><h2>${s}/${q.length}</h2><p>${pct}%</p><div class='badge ${cls}'>${status}</div></div>`;
document.getElementById('next').style.display='none';
document.getElementById('bar').style.width='100%';
}

load();
</script>
</body>
</html>
